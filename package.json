{
  "name": "atrios-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "drizzle-kit migrate && node src/db/seed-provimento.ts && next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "db:seed": "node --env-file=.env src/db/seed.ts",
    "db:seed:provimento": "node --env-file=.env src/db/seed-provimento.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@vercel/blob": "^2.6.1",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "pusher": "^5.3.4",
    "pusher-js": "^8.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
