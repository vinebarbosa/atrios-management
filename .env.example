# Postgres — sem servidor local? suba um:
#   docker run -d --name atrios-pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=atrios postgres:17-alpine
DATABASE_URL=postgres://postgres:postgres@localhost:5432/atrios

# openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# OAuth apps (callback: $BETTER_AUTH_URL/api/auth/callback/<provider>)
# Sem credenciais, o provedor fica desabilitado — email+senha continua funcionando.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cofre de senhas — chave AES-256 dos segredos (openssl rand -base64 32).
# ATENÇÃO: perder a chave torna os segredos do cofre irrecuperáveis.
VAULT_KEY=

# Upload de arquivos da aba Documentos (Vercel Blob).
# Sem o token, o formato "Enviar arquivo" falha com erro claro — o resto da aba funciona.
BLOB_READ_WRITE_TOKEN=

# Envio de convites por email.
# Sem INVITE_EMAIL_PROVIDER (ou sem RESEND_API_KEY), o email cai no log de console.
# Domínio do RESEND_FROM_EMAIL precisa estar verificado na conta Resend.
INVITE_EMAIL_PROVIDER=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Páginas públicas (site institucional em / e landing /diagnostico).
# Para onde vai a notificação de novo lead (default: contato@atrioss.com).
LEAD_NOTIFY_EMAIL=
# Exibe os logos de parceria (Arpen/Anoreg) nas DUAS páginas — só "true" quando
# a parceria estiver formalizada. Qualquer outro valor (ou vazio) = oculto.
LANDING_SHOW_PARTNERS=
# Origem pública do site — base das URLs de og:image, canonical, sitemap e
# robots. Sem ela: VERCEL_URL no preview, https://atrioss.com em produção.
NEXT_PUBLIC_SITE_URL=

# Realtime (Pusher Channels). Crie um app grátis em dashboard.pusher.com e copie
# as 4 credenciais (App Keys). Sem elas, o realtime fica desligado e o app segue
# normal (as telas só atualizam ao navegar/recarregar).
# As NEXT_PUBLIC_* vão pro bundle do browser (são públicas por natureza no Pusher).
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

